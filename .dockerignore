tdxpy/

# Docs — not needed for build
docs/dev/
docs/del/
docs/WORK_LOG_*.md

# Tests, examples, tools — not needed for wheel
tests/
benches/
examples/
tools/

# Example outputs
examples/*.png

# OS
.DS_Store
Thumbs.db
