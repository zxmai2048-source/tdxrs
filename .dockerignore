# ============================================================
# Docker ignore — minimize build context for CI / Linux wheel
# ============================================================

# Git
.git/
.gitignore
.gitattributes

# Rust build cache
/target

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
dist/
build/

# IDE
.idea/
.vscode/

# Claude Code
.claude/
localsession

